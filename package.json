{
    "name": "express-starter",
    "version": "0.0.0",
    "private": true,
    "scripts": {
        "start": "dotenv -e .env.development -- nodemon bin/server.js",
        "start:prod": "dotenv -e .env.production -- forever start bin/server.js",
        "prisma:migrate": "dotenv -e .env.development -- npx prisma migrate dev --name init --schema=src/prisma/schema.prisma",
        "prisma:generate": "npx prisma generate --schema=src/prisma/schema.prisma"
    },
    "dependencies": {
        "@prisma/client": "^4.14.1",
        "cookie-parser": "~1.4.4",
        "debug": "~4.3.4",
        "dotenv": "^16.0.3",
        "ejs": "3.1.7",
        "express": "~4.16.1",
        "http-errors": "~1.6.3",
        "joi": "^17.8.3",
        "md5": "^2.3.0",
        "module-alias": "^2.2.2",
        "moment": "^2.29.4",
        "morgan": "~1.9.1",
        "mount-routes": "^1.0.8",
        "serve-favicon": "^2.5.0"
    },
    "devDependencies": {
        "dotenv-cli": "^7.2.1",
        "forever": "^4.0.3",
        "nodemon": "^2.0.21",
        "prettier": "^2.8.4",
        "prisma": "^4.14.1"
    },
    "_moduleAliases": {
        "@": "./src"
    }
}
